<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue tree IT Affectation -->
    <record id="view_it_affectation_tree" model="ir.ui.view">
        <field name="name">it.affectation.tree</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <tree string="Affectations">
                <field name="equipment_id" />
                <field name="employee_id" />
                <field name="department_id" />
                <field name="assignment_date" />
                <field name="return_date" />
                <field name="is_current" />
            </tree>
        </field>
    </record>

    <!-- Vue form IT Affectation -->
    <record id="view_it_affectation_form" model="ir.ui.view">
        <field name="name">it.affectation.form</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <form string="Affectation">
                <group>
                    <group string="Équipement et employé">
                        <field name="equipment_id" />
                        <field name="employee_id" />
                        <field name="department_id" />
                    </group>
                    <group string="Dates">
                        <field name="assignment_date" />
                        <field name="return_date" />
                        <field name="is_current" />
                    </group>
                </group>
                <field name="reason" nolabel="1" placeholder="Motif..." />
            </form>
        </field>
    </record>

    <!-- Vue search IT Affectation -->
    <record id="view_it_affectation_search" model="ir.ui.view">
        <field name="name">it.affectation.search</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <search>
                <field name="equipment_id" />
                <field name="employee_id" />
                <field name="department_id" />
                <filter name="current" string="Affectations actuelles" domain="[('is_current', '=', True)]" />
                <filter name="returned" string="Retournées" domain="[('return_date', '!=', False)]" />
            </search>
        </field>
    </record>
</odoo>
