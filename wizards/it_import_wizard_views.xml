<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_import_wizard_form" model="ir.ui.view">
        <field name="name">it.import.wizard.form</field>
        <field name="model">it.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importer un inventaire CSV">
                <group states="draft">
                    <group string="Fichier">
                        <field name="csv_file" required="1" />
                        <field name="filename" />
                    </group>
                </group>
                <group states="done">
                    <field name="import_report" nolabel="1" widget="html" />
                </group>
                <footer>
                    <button name="action_import" string="Importer" type="object" class="btn-primary" states="draft" />
                    <button string="Fermer" class="btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
