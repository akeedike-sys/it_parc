<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Règles d'accès pour IT Equipment -->
        <record id="rule_it_equipment_manager_all" model="ir.rule">
            <field name="name">IT Equipment - Manager all</field>
            <field name="model_id" ref="model_it_equipment" />
            <field name="groups" eval="[(4, ref('group_it_manager'))]" />
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_it_equipment_technician_read" model="ir.rule">
            <field name="name">IT Equipment - Technician read</field>
            <field name="model_id" ref="model_it_equipment" />
